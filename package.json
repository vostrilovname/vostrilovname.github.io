{
  "name": "eleventy-base-blog",
  "version": "5.0.2",
  "description": "A starter repository for a blog web site using the Eleventy static site generator.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "upgrade": "npx npm-check-updates -u && rimraf node_modules package-lock.json && npm install",
    "test": "jest --config=./e2e/jest.config.js --verbose false",
    "build": "eleventy",
    "watch": "eleventy --watch",
    "serve": "eleventy --serve",
    "start": "eleventy --serve",
    "debug": "DEBUG=* eleventy"
  },
  "repository": {
    "type": "git",
    "url": "git://github.com/11ty/eleventy-base-blog.git"
  },
  "author": {
    "name": "Zach Leatherman",
    "email": "zachleatherman@gmail.com",
    "url": "https://zachleat.com/"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/11ty/eleventy-base-blog/issues"
  },
  "homepage": "https://github.com/11ty/eleventy-base-blog#readme",
  "devDependencies": {
    "@11ty/eleventy": "^3.1.2",
    "@11ty/eleventy-navigation": "^1.0.5",
    "@11ty/eleventy-plugin-rss": "^2.0.4",
    "@11ty/eleventy-plugin-syntaxhighlight": "^5.0.0",
    "@babel/core": "^7.21.8",
    "@babel/preset-env": "^7.21.5",
    "dayjs": "^1.11.7",
    "eleventy-plugin-blog-tools": "^0.4.1",
    "eleventy-plugin-embed-everything": "^1.16.0",
    "html-entities": "^2.3.3",
    "luxon": "^3.3.0",
    "markdown-it": "^14.1.1",
    "markdown-it-image-figures": "^2.1.1",
    "puppeteer": "^24.38.0",
    "rimraf": "^6.1.3",
    "sitemapper": "^4.1.4"
  }
}
